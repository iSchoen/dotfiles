#
# ‾/.bash_profile
#

[[ -f ‾/.bashrc ]] && . ‾/.bashrc

# Deno completions (generated by: deno completions bash > ‾/.local/share/bash-completion/completions/deno.bash)
[[ -f "$HOME/.local/share/bash-completion/completions/deno.bash" ]] && source "$HOME/.local/share/bash-completion/completions/deno.bash"
